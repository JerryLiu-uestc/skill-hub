{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Hub",
  "version": "0.1.0",
  "identifier": "com.jerry.skillhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Hub",
        "width": 1180,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "dmg": {
        "background": "assets/dmg-background.png",
        "windowSize": {
          "width": 680,
          "height": 420
        },
        "appPosition": {
          "x": 190,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 500,
          "y": 220
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
